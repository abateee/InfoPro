PORT=3010

# Providers de recherche actives par defaut (csv)
SEARCH_PROVIDERS=infonet

# mock ou live
INFONET_MODE=mock

# Base URL Infonet
INFONET_BASE_URL=https://infonet.fr

# Login automatique headless (recommande)
INFONET_EMAIL=
INFONET_PASSWORD=

# 1 = headless (sans fenetre), 0 = visible
INFONET_HEADLESS=1
INFONET_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36

# Nombre max de pages scrapees par recherche
INFONET_MAX_PAGES=3
INFONET_ENRICH_CONTACTS_LIMIT=10

# Timeout navigation navigateur (ms)
INFONET_NAV_TIMEOUT_MS=45000

# Provider officiel Annuaire des Entreprises
ANNUAIRE_BASE_URL=https://recherche-entreprises.api.gouv.fr
ANNUAIRE_TIMEOUT_MS=20000

# Provider Artisan en Ligne
ARTISAN_BASE_URL=https://www.artisan-en-ligne.com
ARTISAN_TIMEOUT_MS=20000
ARTISAN_DETAIL_LIMIT=10
ARTISAN_PHONE_LIMIT=10
ARTISAN_PHONE_DELAY_MS=750
ARTISAN_MAX_CONTEXTS=5
ARTISAN_OPTIONS_TTL_MS=3600000

# Validation INPI des "sans site" avant persistance locale
INPI_BASE_URL=https://registre-national-entreprises.inpi.fr
INPI_USERNAME=
INPI_PASSWORD=
INPI_TIMEOUT_MS=20000
INPI_TOKEN_TTL_MS=2700000
INPI_VALIDATE_LIMIT=25

# Valeurs mock
DEFAULT_NAF_CODES=
DEFAULT_TAGS=
DEFAULT_LIMIT=25

